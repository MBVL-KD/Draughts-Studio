const Puzzle = require("../models/Puzzle");

const createPuzzle = async (req, res) => {
  try {
    console.log("Create puzzle body:", JSON.stringify(req.body, null, 2));

    const puzzle = await Puzzle.create(req.body);
    res.status(201).json(puzzle);
  } catch (err) {
    console.error("Create puzzle error:", err);
    console.error("Create puzzle body:", JSON.stringify(req.body, null, 2));
    res.status(400).json({
      error: "Failed to create puzzle",
      details: err.message,
    });
  }
};

const getPuzzles = async (req, res) => {
  try {
    const puzzles = await Puzzle.find().sort({ createdAt: -1 });
    res.json(puzzles);
  } catch (err) {
    console.error("Get puzzles error:", err);
    res.status(500).json({
      error: "Failed to fetch puzzles",
    });
  }
};

const updatePuzzle = async (req, res) => {
  try {
    const { id } = req.params;
    console.log("Update puzzle body:", JSON.stringify(req.body, null, 2));

    const puzzle = await Puzzle.findByIdAndUpdate(id, req.body, {
      new: true,
      runValidators: true,
    });

    if (!puzzle) {
      return res.status(404).json({
        error: "Puzzle not found",
      });
    }

    res.json(puzzle);
  } catch (err) {
    console.error("Update puzzle error:", err);
    console.error("Update puzzle body:", JSON.stringify(req.body, null, 2));
    res.status(400).json({
      error: "Failed to update puzzle",
      details: err.message,
    });
  }
};

const deletePuzzle = async (req, res) => {
  try {
    const { id } = req.params;

    const deleted = await Puzzle.findByIdAndDelete(id);

    if (!deleted) {
      return res.status(404).json({
        error: "Puzzle not found",
      });
    }

    res.json({
      success: true,
      deletedId: id,
    });
  } catch (err) {
    console.error("Delete puzzle error:", err);
    res.status(400).json({
      error: "Failed to delete puzzle",
      details: err.message,
    });
  }
};

module.exports = {
  createPuzzle,
  getPuzzles,
  updatePuzzle,
  deletePuzzle,
};